{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.net/schemas/manifest.schema.json",
  "title": "Node Feed Manifest",
  "type": "object",
  "required": ["version", "generated_at_utc", "router_runtime_version", "profiles"],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 8
    },
    "generated_at_utc": {
      "type": "string"
    },
    "router_runtime_version": {
      "type": "integer",
      "minimum": 1
    },
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["files"],
        "properties": {
          "set_targets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "files": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["sha256", "size"],
              "properties": {
                "sha256": {
                  "type": "string",
                  "minLength": 64,
                  "maxLength": 64
                },
                "size": {
                  "type": "integer",
                  "minimum": 0
                },
                "kind": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
