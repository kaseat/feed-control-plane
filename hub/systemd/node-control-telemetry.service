[Unit]
Description=Node Control telemetry dashboard and collector
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/node-control/repo/hub
EnvironmentFile=-/etc/node-control/telemetry.env
ExecStart=/usr/bin/python3 /opt/node-control/repo/hub/scripts/telemetry-dashboard.py --config /etc/node-control/telemetry.nodes.json
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
